# Stock Screener Pro - Environment Variables

# ==========================
# Next.js Configuration
# ==========================
NEXT_PUBLIC_APP_NAME=Stock Screener Pro
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENVIRONMENT=development

# ==========================
# Financial API Keys
# ==========================
# Choose ONE primary data source:
# 1. Finnhub.io - Real-time WebSocket (Recommended for live data)
FINNHUB_API_KEY= 

# 2. Alpha Vantage - Free tier (good for learning, limited calls/min)
ALPHA_VANTAGE_API_KEY=

# 3. Polygon.io - Premium features available
POLYGON_API_KEY= 

# 4. IEX Cloud - Real-time data
IEX_CLOUD_API_KEY=

# ==========================
# Data Mode Configuration
# ==========================
# Set to 'live' for real market data, 'simulated' for generated data
NEXT_PUBLIC_DATA_MODE=simulated

# ==========================
# WebSocket Server (Optional)
# ==========================
# If running a separate backend server for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_SERVER_PORT=3001

# ==========================
# API Endpoints
# ==========================
# Backend API URL - adjust based on environment
NEXT_PUBLIC_API_URL=http://localhost:5000/api
API_BASE_URL=http://localhost:5000

# ==========================
# Cache Configuration
# ==========================
# Duration in milliseconds to cache API responses
API_CACHE_DURATION=300000
# Max number of stocks to fetch in one request
MAX_STOCKS_PER_REQUEST=100

# ==========================
# Feature Flags
# ==========================
# Enable real-time price updates
NEXT_PUBLIC_ENABLE_LIVE_UPDATES=true
# Enable historical data replay
NEXT_PUBLIC_ENABLE_REPLAY_MODE=false
# Enable rate limiting protection
NEXT_PUBLIC_ENABLE_RATE_LIMIT_PROTECTION=true
